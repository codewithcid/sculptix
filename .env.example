# ──────────────────────────────────────────────────────────────────────────
# Sculptix — Environment configuration
#
# Copy this file to `.env` and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
#
# These keys are PUBLIC (the anon key is designed to be shipped in the client).
# Real protection comes from Row Level Security policies, not from hiding keys.
# ──────────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Only used by the `db:gen-types` script (CLI), never shipped to the client.
SUPABASE_PROJECT_ID=YOUR-PROJECT-ref
